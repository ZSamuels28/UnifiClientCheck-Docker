# ============================================================
# UniFiClientAlerts — Environment Variable Reference
# ============================================================
# Copy this file to .env and fill in your values.
# Lines starting with # are comments and are ignored.
# ============================================================

# ------------------------------------------------------------
# UniFi Controller (REQUIRED)
# ------------------------------------------------------------
# Use a local account — UniFi Cloud accounts are not supported.
# Recommended: create a View Only role and a dedicated local user.
UNIFI_CONTROLLER_USER=your_local_user
UNIFI_CONTROLLER_PASSWORD=your_password
UNIFI_CONTROLLER_URL=https://192.168.1.1:443
# UNIFI_SITE_ID=default   # Only needed if your site ID is not "default"

# ------------------------------------------------------------
# Notification Service (pick ONE, set to the service name)
# ------------------------------------------------------------
# Options: Telegram, Ntfy, Pushover, Slack, Gotify, Discord, MQTT, Webhook
NOTIFICATION_SERVICE=Telegram

# ------------------------------------------------------------
# Telegram (required if NOTIFICATION_SERVICE=Telegram)
# ------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ------------------------------------------------------------
# Ntfy (required if NOTIFICATION_SERVICE=Ntfy)
# ------------------------------------------------------------
# NTFY_URL=https://ntfy.sh/your-topic
# NTFY_USER=          # optional, for auth-protected topics
# NTFY_PASSWORD=      # optional
# NTFY_EMAIL=         # optional, forward notifications to email

# ------------------------------------------------------------
# Pushover (required if NOTIFICATION_SERVICE=Pushover)
# ------------------------------------------------------------
# PUSHOVER_TOKEN=     # Pushover app token
# PUSHOVER_USER=      # Pushover user key
# PUSHOVER_TITLE=     # optional, notification title
# PUSHOVER_SOUND=     # optional, e.g. pushover, bike, magic

# ------------------------------------------------------------
# Slack (required if NOTIFICATION_SERVICE=Slack)
# ------------------------------------------------------------
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ------------------------------------------------------------
# Gotify (required if NOTIFICATION_SERVICE=Gotify)
# ------------------------------------------------------------
# GOTIFY_URL=http://gotify.example.com
# GOTIFY_TOKEN=       # Gotify app token

# ------------------------------------------------------------
# Discord (required if NOTIFICATION_SERVICE=Discord)
# ------------------------------------------------------------
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/WEBHOOK

# ------------------------------------------------------------
# MQTT (required if NOTIFICATION_SERVICE=MQTT)
# ------------------------------------------------------------
# MQTT_BROKER=tcp://192.168.1.1:1883
# MQTT_TOPIC=unifi/new_device
# MQTT_USER=          # optional
# MQTT_PASSWORD=      # optional
# MQTT_CLIENT_ID=     # optional, defaults to unificlientalerts

# ------------------------------------------------------------
# Webhook (required if NOTIFICATION_SERVICE=Webhook)
# ------------------------------------------------------------
# WEBHOOK_URL=https://your-endpoint.example.com/hook
# WEBHOOK_SECRET=     # optional, sent as Bearer token in Authorization header

# ------------------------------------------------------------
# General Settings (all optional)
# ------------------------------------------------------------
# KNOWN_MACS=AA:BB:CC:DD:EE:FF,11:22:33:44:55:66
#   Comma-separated list of MAC addresses to suppress on first run.

# REMEMBER_NEW_DEVICES=true
#   Store new device MACs in the database so they are not re-alerted.
#   Default: true

# ALWAYS_NOTIFY=false
#   Send a notification on every check for every device, not just new ones.
#   Default: false

# REQUIRE_IP=false
#   Hold notifications until the device has an IP address assigned.
#   Note: WebSocket-triggered devices already wait for an IP with backoff polling.
#   This setting primarily affects fallback polling checks.
#   Default: false

# FALLBACK_INTERVAL=60
#   Seconds between fallback polling checks (safety net alongside WebSocket).
#   Set to -1 to disable fallback polling entirely (WebSocket-only mode).
#   Default: 60

# WS_EVENT_DELAY=3
#   Seconds to wait after a WebSocket event (device connection) before querying the UniFi API
#   to fetch device details. Single flat delay (not exponential). After this delay, if the device
#   has no IP yet, polling continues with exponential backoff (3s → 6s → 12s → 24s).
#   Increase if devices are slow to appear or get incomplete details.
#   Default: 3

# DATABASE_PATH=/data/knownMacs.db
#   Path to the SQLite database inside the container.
#   Default: /data/knownMacs.db

# ------------------------------------------------------------
# Device Removal (optional)
# ------------------------------------------------------------
# REMOVE_OLD_DEVICES=false
#   Remove devices from the known list when they leave the network.
#   When enabled, forgotten devices will trigger a notification on next connection.
#   Default: false

# REMOVE_DELAY=0
#   How long a device must be absent before being forgotten.
#   Supports human-readable format: 30s, 5m, 24h, 7d, 2w (or raw seconds like 86400)
#   Examples:
#     REMOVE_DELAY=30s   # Forget after 30 seconds (for testing)
#     REMOVE_DELAY=24h   # Forget after 24 hours
#     REMOVE_DELAY=7d    # Forget after 7 days
#     REMOVE_DELAY=2w    # Forget after 2 weeks
#   Default: 0 (removes on every check — usually not what you want)

# ------------------------------------------------------------
# Debugging (for development/troubleshooting only)
# ------------------------------------------------------------
# VERBOSE=false
#   Enable verbose logging for diagnostic/troubleshooting output.
#   When false (default): shows operational events — device detected, WebSocket events,
#     fallback checks, no new devices found, errors, etc.
#   When true: also shows polling attempts, per-device skip messages, and internal retry details.
#   Default: false

# WS_DEBUG_LOG=/logs/ws_debug.log
#   Write all raw WebSocket messages to a file for inspection.
